# Required search API configuration.
POEM_API_URL=https://search-provider.example/api/queries
POEM_API_INDEX=poems_index
POEM_API_QUERY_JSON={"api-key":"replace-me","application-id":"replace-me"}
POEM_SEARCH_PARAMS_JSON={"filters":"type:poem AND has_audio:true","query":""}

# Required page URL configuration.
POEM_PAGE_BASE_URL=https://poems.example/

# Optional response field mappings.
POEM_TITLE_FIELD=title
POEM_AUTHORS_FIELD=authors
POEM_CONTENT_FIELD=content
POEM_URI_FIELD=uri
POEM_FALLBACK_URI_FIELD=path
POEM_ID_FIELD=id
POEM_TRANSLATED_BY_FIELD=translated_by
POEM_TRANSLATION_TITLE_FIELD=translation_title

# Optional audio extraction configuration.
POEM_AUDIO_SELECTOR=audio[src]
POEM_AUDIO_URL_REGEX=https?://[^\s"'<>]+\.mp3(?:\?[^\s"'<>]+)?
POEM_TEST_PAGE_URL=https://poems.example/known-audio-poem
POEM_BROWSER_PROFILE=chrome124

# Optional paging and rate limits.
POEM_HITS_PER_PAGE=100
POEM_FETCH_DELAY_SECONDS=1.5
